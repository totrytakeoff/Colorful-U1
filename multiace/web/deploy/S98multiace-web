#!/bin/sh
#
# multiACE Web init script (busybox init / Snapmaker U1).
#
# Caveat: the U1 rcS expands /etc/init.d/S??* BEFORE overlayfs mounts.
# A post-install-time copy of this file lands in the overlay and is
# therefore invisible at next boot. Two ways around that:
#   1) bake the file into the firmware image (paxx-style overlay)
#   2) start it manually after install - install_multiace.sh does that.
# Either way the same script controls the lifecycle.

NAME="multiace-web"
DAEMON_DIR="/home/lava/multiace_web/backend"
DAEMON="/usr/bin/python3"
ARGS="-m uvicorn main:app --host 127.0.0.1 --port 7126 --log-level warning"
PIDFILE="/tmp/multiace_web.pid"
LOGFILE="/home/lava/printer_data/logs/multiace_web.log"
PORT="7126"
# Service runs as root: Snapmaker U1 ships without sudo, but the
# update endpoint has to cp into root-owned dirs (klipper extras,
# /etc/init.d). Closed appliance, attack surface is bound to 127.0.0.1
# behind nginx auth - net risk is minor compared to a broken updater.
USER="root"

export MOONRAKER_URL="${MOONRAKER_URL:-http://127.0.0.1:7125}"
export MULTIACE_CFG_PATH="${MULTIACE_CFG_PATH:-/home/lava/printer_data/config/extended/ace.cfg}"
export MULTIACE_FRONTEND_DIR="${MULTIACE_FRONTEND_DIR:-/home/lava/multiace_web/frontend}"

start() {
    printf "Starting %s: " "$NAME"
    if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
        echo "already running"
        return 1
    fi
    # A stale pidfile can leave an old uvicorn bound to the port while
    # restart appears to succeed.  Clean only the exact multiace-web command.
    STALE_PIDS="$(pgrep -f "uvicorn main:app --host 127.0.0.1 --port $PORT" 2>/dev/null || true)"
    if [ -n "$STALE_PIDS" ]; then
        echo "stale process on port $PORT"
        kill $STALE_PIDS 2>/dev/null || true
        sleep 1
        STALE_PIDS="$(pgrep -f "uvicorn main:app --host 127.0.0.1 --port $PORT" 2>/dev/null || true)"
        if [ -n "$STALE_PIDS" ]; then
            kill -KILL $STALE_PIDS 2>/dev/null || true
            sleep 1
        fi
    fi
    if [ ! -d "$DAEMON_DIR" ]; then
        echo "FAIL ($DAEMON_DIR missing)"
        return 1
    fi
    # Wait for Moonraker to be reachable before launching uvicorn.
    # Without this the backend starts on a fresh boot before Klipper /
    # Moonraker have come up, the initial WS handshake fails, and the
    # FastAPI app sometimes settles into a half-broken state where the
    # frontend renders empty until a manual restart. Up to ~30s.
    n=0
    while [ "$n" -lt 30 ]; do
        if wget -q --spider --timeout=2 \
                "${MOONRAKER_URL%/}/server/info" 2>/dev/null; then
            break
        fi
        sleep 1
        n=$((n + 1))
    done
    # Service runs as root (see USER= above) but Python deps were
    # pip-installed under lava's --user site. Point HOME at /home/lava
    # so /home/lava/.local/lib/python3.11/site-packages is discovered.
    HOME_LAVA="/home/lava"
    PATH_LAVA="${HOME_LAVA}/.local/bin:/usr/bin:/bin"
    start-stop-daemon -S -b -m -p "$PIDFILE" \
        -x /bin/sh -- -c "
            export HOME='$HOME_LAVA' USER='$USER' PATH='$PATH_LAVA';
            cd '$DAEMON_DIR' || exit 1;
            exec $DAEMON $ARGS >>'$LOGFILE' 2>&1
        "
    echo "OK (waited ${n}s for Moonraker)"
}

stop() {
    printf "Stopping %s: " "$NAME"
    if [ -f "$PIDFILE" ]; then
        start-stop-daemon -K -p "$PIDFILE" -s TERM
        rm -f "$PIDFILE"
    fi
    STALE_PIDS="$(pgrep -f "uvicorn main:app --host 127.0.0.1 --port $PORT" 2>/dev/null || true)"
    if [ -n "$STALE_PIDS" ]; then
        kill $STALE_PIDS 2>/dev/null || true
        sleep 1
        STALE_PIDS="$(pgrep -f "uvicorn main:app --host 127.0.0.1 --port $PORT" 2>/dev/null || true)"
        if [ -n "$STALE_PIDS" ]; then
            kill -KILL $STALE_PIDS 2>/dev/null || true
        fi
    fi
    if [ -f "$PIDFILE" ]; then
        rm -f "$PIDFILE"
    fi
    if pgrep -f "uvicorn main:app --host 127.0.0.1 --port $PORT" >/dev/null 2>&1; then
        echo "FAIL"
        return 1
    else
        echo "OK"
    fi
}

restart() { stop; sleep 1; start; }

case "$1" in
    start)        start;;
    stop)         stop;;
    restart|reload) restart;;
    status)
        if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
            echo "$NAME running (pid $(cat "$PIDFILE"))"
        else
            echo "$NAME not running"
        fi
        ;;
    *) echo "Usage: $0 {start|stop|restart|status}"; exit 1;;
esac

exit $?
